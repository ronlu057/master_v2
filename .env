# ── 專案類型 ─────────────────────────────────────────────
# module       模組件套版（首頁 + 內頁皆用 block 模組組裝）
# custom-home  客製首頁（首頁手刻、內頁走 block 模組）
# full-custom  全部客製開發（首頁 + 內頁皆手刻）
# shop         購物類型（客製首頁 + 啟用購物模組）
# temp         臨時站（精簡單頁、快速上線；如「即將開幕」、活動過渡頁）
NUXT_PUBLIC_PROJECT_TYPE=module

# ── API 來源 ─────────────────────────────────────────────
# 留空 = 前端開發階段使用本地 mock JSON（server/routes/api）
# 正式串接時填後端網域，例如：https://hello.show.ad-design.tw
NUXT_PUBLIC_API_BASE=

# ── 多語系 ────────────────────────────────────────────────
# 預設語系：實際被 nuxt.config.js 的 i18n.defaultLocale 讀取
# 支援語系清單請改 nuxt.config.js 的 i18n.locales（目前：tw / en / jp / kr）
# 元件切換：const { setLocale } = useI18n(); setLocale('en')
NUXT_PUBLIC_DEFAULT_LANG=tw

# ── Header 版型 ───────────────────────────────────────────
# 值 = components/headers/ 內的版型檔名（不含 .vue），例如 Header01、header_value
NUXT_PUBLIC_HEADER=Header16

# ── Banner 版型 ───────────────────────────────────────────
# 值 = components/banners/ 內的版型檔名（不含 .vue）
# 內頁 Banner（PageBannerXX）— news / about / contact 等內頁 hero
NUXT_PUBLIC_PAGE_BANNER=PageBanner01
# 首頁 Banner block（BlockBannerXX）— 首頁輪播
NUXT_PUBLIC_BLOCK_BANNER=BlockBanner01

# ── 購物功能開關 ──────────────────────────────────────────
# 是否顯示購物 UI（購物車 / 我的最愛 / 收藏 等）
# shop 類型自動啟用，此值無效；其他類型設 true 可加掛購物功能（混合需求）
NUXT_PUBLIC_ENABLE_SHOP=false


NUXT_PUBLIC_LOGO=
NUXT_PUBLIC_LOGO_MAX_HEIGHT=46

# ── 後台 AI 文案生成（Google Gemini，dev-only）────────────────
# 「免費 AI 生成」標題/副標/說明文用。免費金鑰申請：https://aistudio.google.com/apikey
# ⚠️ 這是「伺服器端私密金鑰」（無 NUXT_PUBLIC_ 前綴 → 不會外洩到前端）。
#    本 .env 有納入版控 → 真實金鑰請勿 commit（填本機即可，或改放 .env.local 並 gitignore）。
NUXT_GEMINI_KEY=
# 可選：覆寫模型（預設 gemini-2.0-flash）
NUXT_GEMINI_MODEL=